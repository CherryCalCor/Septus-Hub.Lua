        if not LP.Character or not LP.Character:FindFirstChild("HumanoidRootPart") then return end

        isFlinging = true
        showNotification("Fling применяется к " .. currentFlingTarget.Name)
        local hrp = LP.Character.HumanoidRootPart
        local oldPos = hrp.CFrame
        
        local bv = Instance.new("BodyAngularVelocity", hrp)
        bv.AngularVelocity = Vector3.new(0, 99999, 0)
        bv.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bv.P = math.huge
        
        local bt = Instance.new("BodyThrust", hrp)
        bt.Force = Vector3.new(9999, 9999, 9999)
        
        LP.Character.Humanoid.Sit = true

        local flingTime = 0
        local flingCon
        flingCon = Services.Run.Stepped:Connect(function(_, dt)
            flingTime = flingTime + dt
            if flingTime > 2.5 or not currentFlingTarget.Character or not currentFlingTarget.Character:FindFirstChild("HumanoidRootPart") then
                if bv then bv:Destroy() end
                if bt then bt:Destroy() end
                hrp.Velocity = Vector3.new()
                hrp.RotVelocity = Vector3.new()
                hrp.CFrame = oldPos
                LP.Character.Humanoid.Sit = false
                isFlinging = false
                flingCon:Disconnect()
                return
            end
            hrp.CFrame = currentFlingTarget.Character.HumanoidRootPart.CFrame
        end)
    end)

    local bringConnection = nil
    local isBringing = false
    BringActionBtn.MouseButton1Click:Connect(function()
        if not currentBringTarget or not currentBringTarget.Character then return end
        local targetHRP = currentBringTarget.Character:FindFirstChild("HumanoidRootPart")
        if not targetHRP then return end

        if isBringing then
            isBringing = false
            if bringConnection then bringConnection:Disconnect(); bringConnection = nil end
            showNotification("Преследование остановлено")
            return
        end

        isBringing = true
        showNotification("Сбор физических объектов к " .. currentBringTarget.Name)

        pcall(function()
            sethiddenproperty(LP, "MaximumSimulationRadius", math.huge)
            sethiddenproperty(LP, "SimulationRadius", math.huge)
        end)

        local function isTargetObject(part)
            if not part:IsA("BasePart") or part.Anchored then return false end
            if part.Parent:FindFirstChildOfClass("Humanoid") then return false end
            if part.Parent:IsA("Accessory") then return false end

            local model = part:FindFirstAncestorOfClass("Model")
            if model and model:FindFirstChildOfClass("VehicleSeat", true) then return true end

            local hasJoint = false
            if part:FindFirstChildOfClass("Constraint") or part:FindFirstChildOfClass("Attachment") then hasJoint = true end
            if not hasJoint and part.Parent then
                if part.Parent:FindFirstChildOfClass("Constraint", true) or part.Parent:FindFirstChildOfClass("Attachment", true) then hasJoint = true end
            end

            if hasJoint then return true end
            local volume = part.Size.X * part.Size.Y * part.Size.Z
            if volume > 15 then return true end
            return false
        end

        local targetParts = {}
        for _, part in pairs(workspace:GetDescendants()) do
            if isTargetObject(part) then
                for _, child in pairs(part:GetDescendants()) do
                    if child:IsA("Constraint") or child:IsA("Attachment") or child:IsA("Weld") or child:IsA("WeldConstraint") then
                        pcall(function() child:Destroy() end)
                    end
                end
                table.insert(targetParts, part)
                part.CanCollide = false 
            end
        end

        bringConnection = Services.Run.Heartbeat:Connect(function()
            if not targetHRP or not targetHRP.Parent then
                isBringing = false
                bringConnection:Disconnect()
                return
            end
            for _, part in pairs(targetParts) do
                if part and part.Parent then
                    part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                    local offset = Vector3.new(math.random(-4, 4), math.random(1, 4), math.random(-4, 4))
                    part.CFrame = targetHRP.CFrame + offset
                end
            end
        end)
    end)
end

