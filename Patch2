    OutlineToggle.MouseButton1Click:Connect(function() outlineESP = not outlineESP; setToggleState(OutlineToggle, OutlineCircle, outlineESP, "ESP Outline") end)
    ItemToggle.MouseButton1Click:Connect(function() itemESP = not itemESP; setToggleState(ItemToggle, ItemCircle, itemESP, "Item ESP") end)

    task.spawn(function()
        while task.wait(.5) do
            for _, plr in pairs(Services.Players:GetPlayers()) do
                if plr ~= LP then
                    if itemESP then
                        for _, obj in pairs(workspace:GetDescendants()) do
                            if (obj:IsA("Tool") or obj.Name:lower():find("gun") or obj.Name:lower():find("key")) and not obj:FindFirstChild("ItemESP") then
                                local part = obj:FindFirstChildWhichIsA("BasePart")
                                if part then
                                    local bb = Instance.new("BillboardGui", obj)
                                    bb.Name = "ItemESP"; bb.Size = UDim2.new(0, 100, 0, 30); bb.AlwaysOnTop = true; bb.Adornee = part
                                    local txt = Instance.new("TextLabel", bb)
                                    txt.Size = UDim2.new(1,0,1,0); txt.BackgroundTransparency = 1; txt.Text = obj.Name; txt.TextScaled = true; txt.TextColor3 = Color3.fromRGB(220, 190, 255)
                                end
                            end
                        end
                    end
                    local char = plr.Character
                    if char and char:FindFirstChild("Head") and char:FindFirstChild("HumanoidRootPart") then
                        if nameESP then
                            local gui = char.Head:FindFirstChild("ESP") or Instance.new("BillboardGui", char.Head)
                            gui.Name = "ESP"; gui.Size = UDim2.new(0,100,0,40); gui.AlwaysOnTop = true; gui.StudsOffset = Vector3.new(0,2,0); gui.Adornee = char.Head
                            local txt = gui:FindFirstChild("TXT") or Instance.new("TextLabel", gui)
                            txt.Name = "TXT"; txt.Size = UDim2.new(1,0,1,0); txt.BackgroundTransparency = 1; txt.TextColor3 = Color3.fromRGB(220, 190, 255); txt.TextStrokeTransparency = 0; txt.Font = Enum.Font.GothamBold; txt.TextScaled = true
                            if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                                local dist = math.floor((LP.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude)
                                txt.Text = plr.Name .. "\n" .. dist .. "m"
                            end
                        else if char.Head:FindFirstChild("ESP") then char.Head.ESP:Destroy() end end

                        if outlineESP then
                            if not char:FindFirstChild("ESPHighlight") then
                                 local hl = Instance.new("Highlight", char)
                                 hl.Name = "ESPHighlight"; hl.FillColor = Color3.fromRGB(220, 190, 255); hl.FillTransparency = 0.7; hl.OutlineColor = Color3.fromRGB(220, 190, 255); hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                            end
                        else if char:FindFirstChild("ESPHighlight") then char.ESPHighlight:Destroy() end end
                    end
                end
            end
        end
    end)
end

