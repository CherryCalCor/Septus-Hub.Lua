local currentPage = UI.Pages.Home
UI.NavBtns.Home.Indicator.BackgroundTransparency = 0 

local function switchTab(btn, page)
    if UI.Frame.Size.Y.Offset < 100 or currentPage == page then return end 
    for _, b in pairs(UI.SideMenuScroll:GetChildren()) do
        if b:IsA("TextButton") and b:FindFirstChild("Indicator") then
             Services.TS:Create(b.Indicator, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
        end
    end
    Services.TS:Create(btn.Indicator, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()

    if currentPage then
        local oldPage = currentPage
        Services.TS:Create(oldPage, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(0, 110, 0, 50)}):Play()
        task.delay(0.2, function() if currentPage ~= oldPage then oldPage.Visible = false end end)
    end
    page.Visible = true
    page.Position = UDim2.new(0, 110, 0, 30) 
    Services.TS:Create(page, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(0, 110, 0, 40)}):Play()
    currentPage = page
end

