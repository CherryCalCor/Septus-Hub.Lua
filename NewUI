        local char = game.Players.LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end

        isFlinging = true
        local hrp = char.HumanoidRootPart
        local oldPos = hrp.CFrame
        
        local bv = Instance.new("BodyAngularVelocity")
        bv.AngularVelocity = Vector3.new(0, 99999, 0)
        bv.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bv.P = math.huge
        bv.Parent = hrp
        
        local bt = Instance.new("BodyThrust")
        bt.Force = Vector3.new(9999, 9999, 9999)
        bt.Parent = hrp
        
        char.Humanoid.Sit = true

        local flingTime = 0
        local flingCon
        flingCon = RunService.Stepped:Connect(function(_, dt)
            flingTime = flingTime + dt
            if flingTime > 2.5 or not currentFlingTarget.Character or not currentFlingTarget.Character:FindFirstChild("HumanoidRootPart") then
                if bv then bv:Destroy() end
                if bt then bt:Destroy() end
                hrp.Velocity = Vector3.new()
                hrp.RotVelocity = Vector3.new()
                hrp.CFrame = oldPos
                char.Humanoid.Sit = false
                isFlinging = false
                flingCon:Disconnect()
                return
            end
            hrp.CFrame = currentFlingTarget.Character.HumanoidRootPart.CFrame
        end)
    end)

