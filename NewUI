-- Функция для добавления черно-нежно-фиолетового градиента
local function applyGradient(obj)
    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(15, 15, 20)), -- Черный/темный
        ColorSequenceKeypoint.new(1, Color3.fromRGB(130, 90, 180)) -- Нежно-фиолетовый
    })
    grad.Rotation = 45
    grad.Parent = obj
end

