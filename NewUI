-- Функция красивого переключения вкладок со слайд анимацией и индикатором
local function switchTab(btn, page)
    if Frame.Size.Y.Offset < 100 or currentPage == page then return end -- проверка если свернуто

    -- Скрываем все индикаторы
    for _, b in pairs(SideMenuScroll:GetChildren()) do
        if b:IsA("TextButton") and b:FindFirstChild("Indicator") then
            TweenService:Create(b.Indicator, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
        end
    end
    
    -- Показываем индикатор активной вкладки
    TweenService:Create(btn.Indicator, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()

    if currentPage then
        local oldPage = currentPage
        TweenService:Create(oldPage, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(0, 110, 0, 50)}):Play()
        task.delay(0.2, function()
            if currentPage ~= oldPage then oldPage.Visible = false end
        end)
    end

    page.Visible = true
    page.Position = UDim2.new(0, 110, 0, 30) -- Начинаем чуть выше
    TweenService:Create(page, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(0, 110, 0, 40)}):Play()
    currentPage = page
end

HomeBtn.MouseButton1Click:Connect(function() switchTab(HomeBtn, HomePage) end)
