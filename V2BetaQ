do -- Moved Page (Управление Полетом переведено на TextBox)
    local y = 10
    local FlyBG, FlyCircle = createToggle(UI.Pages.Moved, "Fly Mode", y)
    local flyEnabled = false
    local flySpeed = 50
    
    FlyBG.MouseButton1Click:Connect(function()
        flyEnabled = not flyEnabled
        setToggleState(FlyBG, FlyCircle, flyEnabled, "Fly Mode")
    end)
    y = y + 40
    
    -- TextBox взамен неудобного ползунка
    local SpeedBox = createTextBox(UI.Pages.Moved, "Fly Speed (Keyboard Input)", "50", y)
    SpeedBox.FocusLost:Connect(function(enterPressed)
        local num = tonumber(SpeedBox.Text)
        if num then
            flySpeed = num
            _G.showNotification("Скорость полета установлена на: " .. flySpeed)
        else
            SpeedBox.Text = tostring(flySpeed)
            _G.showNotification("Ошибка: Введите число!")
        end
    end)
    
    task.spawn(function()
        local keys = {W = false, S = false, A = false, D = false, Space = false, LeftShift = false}
        Services.UIS.InputBegan:Connect(function(i, g)
            if g then return end
            local code = i.KeyCode.Name
            if keys[code] ~= nil then keys[code] = true end
        end)
        Services.UIS.InputEnded:Connect(function(i)
            local code = i.KeyCode.Name
            if keys[code] ~= nil then keys[code] = false end
        end)
        
        Services.Run.Heartbeat:Connect(function()
            if flyEnabled and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = LP.Character.HumanoidRootPart
                local cam = workspace.CurrentCamera
                local dir = Vector3.new()
                
                if keys.W then dir = dir + cam.CFrame.LookVector end
                if keys.S then dir = dir - cam.CFrame.LookVector end
                if keys.A then dir = dir - cam.CFrame.RightVector end
                if keys.D then dir = dir + cam.CFrame.RightVector end
                if keys.Space then dir = dir + Vector3.new(0, 1, 0) end
                if keys.LeftShift then dir = dir - Vector3.new(0, 1, 0) end
                
                if dir.Magnitude > 0 then
                    hrp.Velocity = dir.Unit * flySpeed
                else
                    hrp.Velocity = Vector3.new(0, 0, 0)
                end
            end
        end)
    end)
end

