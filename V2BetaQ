        if s and r and r.data then
            local servers = {}
            for _, srv in pairs(r.data) do if srv.playing and srv.maxPlayers and srv.playing < srv.maxPlayers then table.insert(servers, srv) end end
            table.sort(servers, function(a, b) return srvSortAscending and a.playing < b.playing or a.playing > b.playing end)
