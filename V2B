-- Функция для добавления градиента
local function applyGradient(obj)
    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, currentThemeColor1),
        ColorSequenceKeypoint.new(1, currentThemeColor2)
    })
    grad.Rotation = 45
    grad.Parent = obj
    table.insert(allGradients, grad)
end

-- Функция смены темы
local function changeTheme(c1, c2)
    currentThemeColor1 = c1
    currentThemeColor2 = c2
    for _, grad in pairs(allGradients) do
        if grad and grad.Parent then
            grad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, c1),
                ColorSequenceKeypoint.new(1, c2)
            })
        end
    end
end

