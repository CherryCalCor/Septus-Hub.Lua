    JumpSlider.Position = UDim2.new(0, 10, 0, 115)

    local JumpFill = Instance.new("Frame", JumpSlider)
    JumpFill.Size = UDim2.new(0, 0, 1, 0)
    JumpFill.BackgroundColor3 = Color3.fromRGB(220,190,255)
    JumpFill.BorderSizePixel = 0
    Instance.new("UICorner", JumpFill)

    local JumpKnob = Instance.new("Frame", JumpSlider)
    JumpKnob.Size = UDim2.new(0, 16, 0, 16)
    JumpKnob.Position = UDim2.new(0, -8, 0.5, -8)
    JumpKnob.BackgroundColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", JumpKnob).CornerRadius = UDim.new(1, 0)

    local jump = 50
    local jumpDragging = false

    local function setJump(x)
        local percent = math.clamp((x - JumpSlider.AbsolutePosition.X) / JumpSlider.AbsoluteSize.X, 0, 1)
        jump = math.floor(50 + (200 - 50) * percent)
        JumpLabel.Text = "Jump: " .. jump
        JumpFill.Size = UDim2.new(percent, 0, 1, 0)
        JumpKnob.Position = UDim2.new(percent, -8, 0.5, -8)
        
        local char = game.Players.LocalPlayer.Character
        if char then
            local hum = char:FindFirstChild("Humanoid")
            if hum then
                hum.UseJumpPower = true
                hum.JumpPower = jump
            end
        end
    end

    JumpSlider.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            jumpDragging = true
            setJump(i.Position.X)
        end
    end)

    UIS.InputChanged:Connect(function(i)
        if jumpDragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            setJump(i.Position.X)
        end
    end)

    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then jumpDragging = false end
    end)

    local EJToggle, EJCircle = createToggle(MovedPage, "Endless Jump", 170)
    local endless = false

    EJToggle.MouseButton1Click:Connect(function()
        endless = not endless
        setToggleState(EJToggle, EJCircle, endless, "Endless Jump")
    end)

    UIS.JumpRequest:Connect(function()
        if endless and game.Players.LocalPlayer.Character then
            local hum = game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
        end
    end)

    local WallToggle, WallCircle = createToggle(MovedPage, "Climbing Walls", 220)
    local wall = false

    WallToggle.MouseButton1Click:Connect(function()
        wall = not wall
        setToggleState(WallToggle, WallCircle, wall, "Climbing Walls")
    end)

    task.spawn(function()
        while task.wait() do
            if wall and game.Players.LocalPlayer.Character then
                local hum = game.Players.LocalPlayer.Character:FindFirstChild("Humanoid")
                if hum then hum:ChangeState(Enum.HumanoidStateType.Climbing) end
            end
        end
    end)
end

