-- ИСПРАВЛЕННАЯ ФУНКЦИЯ для переключения тоглов
local function setToggleState(bg, circle, state, toggleName)
    TweenService:Create(circle, TweenInfo.new(.2), {Position = state and UDim2.new(1,-27,.5,-12) or UDim2.new(0,3,.5,-12)}):Play()
    if state then
        bg.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        applyGradient(bg)
    else
        for _, v in pairs(bg:GetChildren()) do
            if v:IsA("UIGradient") then v:Destroy() end
        end
        bg.BackgroundColor3 = Color3.fromRGB(50,50,60)
    end
  
    if toggleName then
        showNotification(toggleName .. (state and " включен!" or " выключен."))
    end
end

