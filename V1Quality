local function populateServers()
    for _, v in pairs(SrvListScroll:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end

    local success, result = pcall(function()
        return game:HttpGet("https://games.roblox.com/v1/games/" .. tostring(game.PlaceId) .. "/servers/Public?sortOrder=Asc&limit=100")
    end)

    if success and result then
        local decoded = HttpService:JSONDecode(result)
        if decoded and decoded.data then
            local servers = {}
            for _, srv in pairs(decoded.data) do
                if srv.playing and srv.maxPlayers and srv.playing < srv.maxPlayers then
                    table.insert(servers, srv)
                end
            end

            table.sort(servers, function(a, b)
                if srvSortAscending then
                    return a.playing < b.playing
                else
                    return a.playing > b.playing
                end
            end)

            for _, srv in ipairs(servers) do
                local item = Instance.new("Frame")
                item.Size = UDim2.new(1, -10, 0, 35)
                item.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
                item.BackgroundTransparency = 0.5
                Instance.new("UICorner", item).CornerRadius = UDim.new(0, 6)

                local info = Instance.new("TextLabel", item)
                info.Size = UDim2.new(0, 200, 1, 0)
                info.Position = UDim2.new(0, 10, 0, 0)
                info.BackgroundTransparency = 1
                info.Text = "Players: " .. srv.playing .. "/" .. srv.maxPlayers .. "  |  Ping: " .. (srv.ping or "?")
                info.TextColor3 = Color3.new(1, 1, 1)
                info.Font = Enum.Font.Gotham
                info.TextSize = 13
                info.TextXAlignment = Enum.TextXAlignment.Left

                local joinBtn = Instance.new("TextButton", item)
                joinBtn.Size = UDim2.new(0, 60, 0, 25)
                joinBtn.Position = UDim2.new(1, -70, 0.5, -12.5)
                joinBtn.BackgroundColor3 = Color3.fromRGB(220, 190, 255)
                joinBtn.Text = "Join"
                joinBtn.TextColor3 = Color3.fromRGB(20, 20, 25)
                joinBtn.Font = Enum.Font.GothamBold
                Instance.new("UICorner", joinBtn).CornerRadius = UDim.new(0, 6)

                joinBtn.MouseButton1Click:Connect(function()
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, srv.id, game.Players.LocalPlayer)
                end)

                item.Parent = SrvListScroll
            end
        end
    end
    SrvListScroll.CanvasSize = UDim2.new(0, 0, 0, srvListLayout.AbsoluteContentSize.Y + 10)
end

