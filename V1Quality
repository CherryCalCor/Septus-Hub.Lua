UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.W then fcKeys.W = true
    elseif input.KeyCode == Enum.KeyCode.A then fcKeys.A = true
    elseif input.KeyCode == Enum.KeyCode.S then fcKeys.S = true
    elseif input.KeyCode == Enum.KeyCode.D then fcKeys.D = true
    elseif input.KeyCode == Enum.KeyCode.Space then fcKeys.Space = true
    elseif input.KeyCode == Enum.KeyCode.LeftShift then fcKeys.LeftShift = true end
end)

UIS.InputEnded:Connect(function(input, gpe)
    if input.KeyCode == Enum.KeyCode.W then fcKeys.W = false
    elseif input.KeyCode == Enum.KeyCode.A then fcKeys.A = false
    elseif input.KeyCode == Enum.KeyCode.S then fcKeys.S = false
    elseif input.KeyCode == Enum.KeyCode.D then fcKeys.D = false
    elseif input.KeyCode == Enum.KeyCode.Space then fcKeys.Space = false
    elseif input.KeyCode == Enum.KeyCode.LeftShift then fcKeys.LeftShift = false end
end)

RunService.RenderStepped:Connect(function()
    if freeCamEnabled then
        local moveVector = Vector3.new()
        if fcKeys.W then moveVector = moveVector + Vector3.new(0, 0, -1) end
        if fcKeys.S then moveVector = moveVector + Vector3.new(0, 0, 1) end
        if fcKeys.A then moveVector = moveVector + Vector3.new(-1, 0, 0) end
        if fcKeys.D then moveVector = moveVector + Vector3.new(1, 0, 0) end
        if fcKeys.Space then moveVector = moveVector + Vector3.new(0, 1, 0) end
        if fcKeys.LeftShift then moveVector = moveVector + Vector3.new(0, -1, 0) end
        cam.CFrame = cam.CFrame * CFrame.new(moveVector * fcSpeed)
    end
end)

