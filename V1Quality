MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        Frame:TweenSize(UDim2.new(0,437,0,35), "Out", "Quad", 0.2, true)
        SideMenuScroll.Visible = false
        SideBar.Visible = false
        hideAllPages()
    else
        Frame:TweenSize(UDim2.new(0,437,0,238), "Out", "Quad", 0.2, true)
        SideMenuScroll.Visible = true
        SideBar.Visible = true
    end
end)

