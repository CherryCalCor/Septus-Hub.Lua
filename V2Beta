            if not part:IsA("BasePart") or part.Anchored then return false end; if part.Parent:FindFirstChildOfClass("Humanoid") then return false end; if part.Parent:IsA("Accessory") then return false end
            local model = part:FindFirstAncestorOfClass("Model"); if model and model:FindFirstChildOfClass("VehicleSeat", true) then return true end
            local hasJoint = false; if part:FindFirstChildOfClass("Constraint") or part:FindFirstChildOfClass("Attachment") then hasJoint = true end; if not hasJoint and part.Parent then if part.Parent:FindFirstChildOfClass("Constraint", true) or part.Parent:FindFirstChildOfClass("Attachment", true) then hasJoint = true end end
            if hasJoint then return true end; if part.Size.X * part.Size.Y * part.Size.Z > 15 then return true end; return false
        end
        local targetParts = {}
        for _, part in pairs(workspace:GetDescendants()) do
            if isTargetObject(part) then for _, child in pairs(part:GetDescendants()) do if child:IsA("Constraint") or child:IsA("Attachment") or child:IsA("Weld") or child:IsA("WeldConstraint") then pcall(function() child:Destroy() end) end end; table.insert(targetParts, part); part.CanCollide = false end
        end
        bringConnection = Services.Run.Heartbeat:Connect(function()
            if not targetHRP or not targetHRP.Parent then isBringing = false; bringConnection:Disconnect(); return end
            for _, part in pairs(targetParts) do if part and part.Parent then part.AssemblyLinearVelocity = Vector3.new(0, 0, 0); part.AssemblyAngularVelocity = Vector3.new(0, 0, 0); part.CFrame = targetHRP.CFrame + Vector3.new(math.random(-4, 4), math.random(1, 4), math.random(-4, 4)) end end
        end)
    end)
end

