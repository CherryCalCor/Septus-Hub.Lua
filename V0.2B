-- свернуть GUI
local minimized = false

MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized

    if minimized then
        Frame:TweenSize(
            UDim2.new(0,437,0,35),
            Enum.EasingDirection.Out,
            Enum.EasingStyle.Quad,
            0.2,
            true
        )
    else
        Frame:TweenSize(
            UDim2.new(0,437,0,238),
            Enum.EasingDirection.Out,
            Enum.EasingStyle.Quad,
            0.2,
            true
        )
    end
end)

