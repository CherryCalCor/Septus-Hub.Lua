local function makeDraggable(guiObj, dragHandle)
    dragHandle = dragHandle or guiObj
    local dragging, dragStart, startPos
    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true; dragStart = input.Position; startPos = guiObj.Position end
    end)
    dragHandle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
    Services.UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            guiObj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

local function createToggle(parent, name, y, defaultState, callback)
    local label = Instance.new("TextLabel", parent)
    label.Text = name
    label.Size = UDim2.new(0, 150, 0, 30); label.Position = UDim2.new(0, 0, 0, y); label.BackgroundTransparency = 1; label.TextColor3 = Color3.fromRGB(220, 190, 255)
    label.Font = Enum.Font.Gotham
    
    local bg = Instance.new("TextButton", parent)
    bg.Text = ""
    bg.Size = UDim2.new(0, 60, 0, 30); bg.Position = UDim2.new(1, -65, 0, y); bg.BackgroundColor3 = Color3.fromRGB(255, 255, 255);
    applyGradient(bg)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)
    
    local circle = Instance.new("Frame", bg)
    circle.Size = UDim2.new(0, 24, 0, 24)
    circle.Position = UDim2.new(0, 3, 0.5, -12); circle.BackgroundColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)
    
    local state = defaultState or false
    
    local function updateVisuals(st, showNotif)
        Services.TS:Create(circle, TweenInfo.new(.2), {Position = st and UDim2.new(1,-27,.5,-12) or UDim2.new(0,3,.5,-12)}):Play()
        if st then
            bg.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            applyGradient(bg)
        else
            for _, v in pairs(bg:GetChildren()) do if v:IsA("UIGradient") then v:Destroy() end end
            bg.BackgroundColor3 = Color3.fromRGB(50,50,60)
        end
        if showNotif then showNotification(name .. (st and " включен!" or " выключен.")) end
    end

    local function setState(newState, isLoad)
        state = newState
        updateVisuals(state, not isLoad)
        _G.ConfigState[name] = state
        if callback then callback(state) end
    end

    bg.MouseButton1Click:Connect(function() setState(not state, false) end)
    _G.ConfigUpdaters[name] = function(val) setState(val, true) end
    
    updateVisuals(state, false)
    _G.ConfigState[name] = state
    
    return bg, circle, setState
end

local function createSlider(parent, yPos, name, min, max, default, callback)
    local bg = Instance.new("TextButton", parent)
    bg.Text = ""
    bg.AutoButtonColor = false
    bg.Size = UDim2.new(1,-20,0,8); bg.Position = UDim2.new(0, 10, 0, yPos + 25); bg.BackgroundColor3 = Color3.fromRGB(50,50,60)
    Instance.new("UICorner", bg)
    local lbl = Instance.new("TextLabel", parent); lbl.Size = UDim2.new(1,0,0,25)
    lbl.Position = UDim2.new(0, 0, 0, yPos); lbl.BackgroundTransparency = 1; lbl.Text = name .. ": " .. default
    lbl.TextColor3 = Color3.fromRGB(220, 190, 255)
    lbl.Font = Enum.Font.GothamBold; lbl.TextXAlignment = Enum.TextXAlignment.Left
    local fill = Instance.new("Frame", bg); fill.Size = UDim2.new((default-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = Color3.fromRGB(220,190,255); Instance.new("UICorner", fill)
    local knob = Instance.new("Frame", bg)
    knob.Size = UDim2.new(0, 16, 0, 16); knob.Position = UDim2.new((default-min)/(max-min), -8, 0.5, -8); knob.BackgroundColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    
    local dragging = false
    local function update(x, isValue)
        local p, val
        if isValue then
            val = math.clamp(x, min, max)
            p = (val - min) / (max - min)
        else
            p = math.clamp((x - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
            val = math.floor(min + (max - min) * p)
        end
        lbl.Text = name .. ": " .. val
        fill.Size = UDim2.new(p, 0, 1, 0); knob.Position = UDim2.new(p, -8, 0.5, -8)
        _G.ConfigState[name] = val
        if callback then callback(val) end
    end
    
    bg.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = true; update(i.Position.X) end end)
    Services.UIS.InputChanged:Connect(function(i) if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then update(i.Position.X) end end)
    Services.UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
    
    _G.ConfigUpdaters[name] = function(val) update(val, true) end
    _G.ConfigState[name] = default
end

